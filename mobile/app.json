{
  "expo": {
    "name": "Music Minion",
    "slug": "music-minion",
    "version": "0.0.1",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "scheme": "music-minion",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "package": "com.musicminion.app",
      "intentFilters": [
        {
          "action": "SEND",
          "category": [
            "DEFAULT"
          ],
          "data": [
            {
              "mimeType": "text/plain"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7e39ff3d-0b77-4ea1-954e-bd7259e70b64"
      }
    }
  }
}
